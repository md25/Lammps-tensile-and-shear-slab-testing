# Make sure the system is equilibrated properly or else graph wont pass throught the origin. Indivdually equilibrate pxz and pyz for shear.
#900 and 1200K data is noisy use average or use a filter - Savitzky-Golay filter or Whittaker-Eilers smoother, preferably the later one.

clear
units           metal
atom_style      atomic
boundary        p p s

read_data       equilibrated_vol_900K.data

pair_style      meam
pair_coeff      * * kim_library.meam Al Ti kim_AlTi.meam Al Ti
neighbor        2.0 bin
neigh_modify    every 2

timestep        0.001

variable        z_min equal "bound(all,zmin)"
variable        z_max equal "bound(all,zmax)"
variable        L0 equal "v_z_max - v_z_min" # Initial Height
print           "Initial Height, L0: ${L0}"

variable        fixed_hi equal "v_z_min + 4.0"    # Thickness of fixed layer
variable        top_lo equal "v_z_max - 4.0"      # Thickness of moving layer

region          bottom block INF INF INF INF v_z_min v_fixed_hi
region          top block INF INF INF INF v_top_lo v_z_max
region          mobile block INF INF INF INF v_fixed_hi v_top_lo # Middle section

group           bottom region bottom
group           top region top
group           mobile region mobile

variable        my_dt equal 0.001
variable        total_steps equal ( 50000 * 1.4 )
variable        target_shear_strain equal ( 0.005 * 1.4 )
variable        vel_shear_y equal "v_target_shear_strain * v_L0 / (v_total_steps * v_my_dt)"
print           "Calculated vel_shear_y for ${target_shear_strain} shear strain at ${total_steps} steps: ${vel_shear_y}"

reset_timestep  0

fix 1 mobile nvt temp 900.0 900.0 0.1
fix 2 bottom setforce 0.0 0.0 0.0
fix 3 top move linear 0.0 ${vel_shear_y} 0.0


variable shear_stress_gpa equal "-pyz/10000" 

variable shear_strain equal "(v_vel_shear_y * step * v_my_dt) / v_L0"

fix stress_curve all print 800 "${shear_strain} ${shear_stress_gpa}" file shear_stress_900K5.txt screen no



compute peratom_stress all stress/atom NULL


thermo 800
thermo_style custom step v_shear_strain v_shear_stress_gpa temp pxx pyy pzz pyz press

# c_peratom_stress[1]=xx, [2]=yy, [3]=zz, [4]=xy, [5]=xz, [6]=yz
dump 1 all custom 800 900k_sheardbhdfhg_no_def5.lammpstrj id type x y z c_peratom_stress[1] c_peratom_stress[2] c_peratom_stress[3] c_peratom_stress[4] c_peratom_stress[5] c_peratom_stress[6]
dump_modify 1 sort id


run             ${total_steps}
print "All done"
